# ─────────────────────────────────────────────
# WhatsCLI — .gitignore
# ─────────────────────────────────────────────

# ── Node.js ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
# package-lock.json must be committed for reproducible installs
yarn.lock
pnpm-lock.yaml

# ── TypeScript Build ──────────────────────────
dist/
build/
*.tsbuildinfo
*.js.map
*.d.ts.map

# ── WhatsCLI Runtime Data ─────────────────────
# User's local store — never version these
~/.whatscli/
.whatscli/

# Session / Auth State — NEVER commit credentials
auth_info_multi/
auth_state/
*.json.credentials
baileys_store.json

# SQLite databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Downloaded media
media/
downloads/

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── Environment ───────────────────────────────
.env
.env.*
!.env.example
.tool-versions

# ── OS ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Editors ───────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Coverage & Tests ──────────────────────────
coverage/
.nyc_output/

# ── Temporary files ───────────────────────────
tmp/
temp/
*.tmp

# ── Agent ───────────────────────────────────
Docs/
.agent/
