{
  "name": "whatscli",
  "version": "0.8.2",
  "description": "WhatsApp Web CLI powered by Baileys — a wacli-compatible alternative optimized for OpenClaw",
  "main": "dist/index.js",
  "bin": {
    "whatscli": "./dist/index.js"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && tsc-alias",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "clean": "rm -rf dist"
  },
  "vitest": {
    "environment": "node"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "whatsapp",
    "cli",
    "baileys",
    "automation",
    "openclaw"
  ],
  "author": "TeeBee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thiagobarbosa-dev/whatscli.git"
  },
  "bugs": {
    "url": "https://github.com/thiagobarbosa-dev/whatscli/issues"
  },
  "homepage": "https://github.com/thiagobarbosa-dev/whatscli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "latest",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "mime-types": "^3.0.2",
    "node-sqlite3-wasm": "^0.8.56",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode-terminal": "^0.12.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
